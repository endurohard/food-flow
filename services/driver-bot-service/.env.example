# Telegram bot token from @BotFather (empty = bot disabled, only /health runs)
DRIVER_BOT_TOKEN=

# Postgres connection (user linking + notification polling)
DATABASE_URL=postgresql://foodflow:foodflow@postgres:5432/foodflow

# Wholesale service API (business actions: deliver / pay / returns)
WHOLESALE_SERVICE_URL=http://wholesale-service:3013

# Shared secret for inter-service auth (X-Internal-Token)
INTERNAL_TOKEN=

# Delivery notification polling interval, ms
POLL_INTERVAL_MS=30000

PORT=3015
